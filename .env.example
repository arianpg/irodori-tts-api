# Copy this file to .env and fill in your values.

# ---------------------------------------------------------------------------
# Model sources
# ---------------------------------------------------------------------------
HF_CHECKPOINT_VOICEDESIGN=Aratako/Irodori-TTS-500M-v2-VoiceDesign
HF_CHECKPOINT_BASE=Aratako/Irodori-TTS-500M-v2

# ---------------------------------------------------------------------------
# Device / precision
# ---------------------------------------------------------------------------
MODEL_DEVICE=cuda
CODEC_DEVICE=cuda
MODEL_PRECISION=bf16
CODEC_PRECISION=bf16

# ---------------------------------------------------------------------------
# Generation defaults
# ---------------------------------------------------------------------------
NUM_STEPS=40
CFG_SCALE_TEXT=3.0
CFG_SCALE_CAPTION=4.0
CFG_SCALE_SPEAKER=5.0
# Buffer multiplier applied to the per-sentence duration estimate (chars / 5.0 * multiplier, min 3s)
SECONDS_BUFFER_MULTIPLIER=1.5

# ---------------------------------------------------------------------------
# Model cache
# ---------------------------------------------------------------------------
# Seconds to keep a loaded model in VRAM after the last request
MODEL_TTL=300
# Seconds to wait for model load before returning 503
MODEL_LOAD_TIMEOUT=300
